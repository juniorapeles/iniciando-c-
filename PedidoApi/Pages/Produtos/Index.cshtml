@page
@model PedidoApi.Pages.Produtos.IndexModel
@{
    Layout = "_Layout";
    ViewData["Title"] = "Produtos";
}

<h2>Produtos</h2>

<table class="table table-striped mt-3">
    <thead>
    <tr>
        <th>Id</th>
        <th>Nome</th>
        <th>Preço</th>
    </tr>
    </thead>
    <tbody>
    @foreach (var produto in Model.Produtos)
    {
        <tr>
            <td>@produto.Id</td>
            <td>@produto.Nome</td>
            <td>@produto.Preco:C</td>
        </tr>
    }
    </tbody>
</table>

<div class="mt-4">
    <a href="/Produtos/Create" class="btn btn-success">Adicionar Produto</a>
</div>