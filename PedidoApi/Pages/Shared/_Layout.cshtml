<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - PedidoApp</title>
    <link rel="icon" type="image/x-icon" href="~/favicon.ico" />
    <!-- Bootstrap CSS via CDN -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
</head>
<body>
<header class="bg-dark text-white p-3 mb-4">
    <div class="container">
        <h1>PedidoApp</h1>
        <nav>
            <a class="text-white me-3" href="/">Home</a>
            <a class="text-white me-3" href="/Clientes">Clientes</a>
            <a class="text-white me-3" href="/Produtos">Produtos</a>
            <a class="text-white" href="/Pedidos">Pedidos</a>
        </nav>
    </div>
</header>

<main class="container">
    @RenderBody()
</main>

<footer class="text-center mt-4 mb-3">
    &copy; 2026 PedidoApp
</footer>

<!-- Bootstrap JS via CDN -->
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>