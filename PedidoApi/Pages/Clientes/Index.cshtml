@page
@model PedidoApi.Pages.Clientes.IndexModel
@{
    Layout = "_Layout";
    ViewData["Title"] = "Clientes";
}

<h2>Gerenciar Clientes</h2>

<!-- Formulário para criar cliente -->
<form method="post" class="mb-4">
    <div class="mb-3">
        <label for="Nome" class="form-label">Nome</label>
        <input type="text" class="form-control" id="Nome" name="Cliente.Nome" value="@Model.Cliente.Nome" required />
    </div>
    <div class="mb-3">
        <label for="Email" class="form-label">Email</label>
        <input type="email" class="form-control" id="Email" name="Cliente.Email" value="@Model.Cliente.Email" required />
    </div>
    <button type="submit" class="btn btn-primary">Criar Cliente</button>
</form>

<!-- Mensagem de sucesso -->
@if (!string.IsNullOrEmpty(Model.Mensagem))
{
    <div class="alert alert-success">@Model.Mensagem</div>
}

<!-- Lista de clientes -->
<table class="table table-striped">
    <thead>
    <tr>
        <th>Id</th>
        <th>Nome</th>
        <th>Email</th>
    </tr>
    </thead>
    <tbody>
    @foreach (var cliente in Model.Clientes)
    {
        <tr>
            <td>@cliente.Id</td>
            <td>@cliente.Nome</td>
            <td>@cliente.Email</td>
        </tr>
    }
    </tbody>
</table>